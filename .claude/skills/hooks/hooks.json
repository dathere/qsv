{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/cowork-setup.cjs\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "PROMPT=$(jq -r '.prompt // empty' | cut -c1-2000); [ -n \"$PROMPT\" ] && qsv log user_prompt \"u-$(uuidgen)\" \"[user_prompt] $PROMPT\" >/dev/null 2>&1 || true"
          }
        ]
      }
    ]
  }
}
