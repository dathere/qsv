{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022"],
    "moduleResolution": "node",
    "baseUrl": ".claude/skills",
    "outDir": ".claude/skills/dist",
    "rootDir": ".claude/skills/src",
    "declaration": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": [".claude/skills/src/**/*"],
  "exclude": [".claude/skills/node_modules", ".claude/skills/dist"]
}
